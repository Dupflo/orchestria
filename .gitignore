# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*

# next.js / build
/.next/
/out/
/build
/coverage

# misc
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env — never commit real env; .env.example is the documented template
.env*
!.env.example

# vercel
.vercel

# typescript (generated)
*.tsbuildinfo
next-env.d.ts

# local editor / agent state
/.cursor/
/.claude/
/.idea/
/.vscode/

# ── OrchestrIA runtime — NEVER commit databases, logs, memory, keys ──────────
# Databases & backups (any name, anywhere)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.bak
*.bak-*

# Runtime state, audit & signing key
/.orchestria/remote-audit.jsonl
/.orchestria/remote.key
/.orchestria/runs/
/.orchestria/agents/*/memory/
/.orchestria/agents/*/logs/
/.orchestria/skills/*/state.json
/.orchestria/skills/*/session.json

# ── Secrets — channel credentials. Only *.json.example is tracked ───────────
/.orchestria/channels/*.json
!/.orchestria/channels/*.json.example

# ── Private agents & skills: deny-all, allow only the OSS defaults ──────────
# Every agent/skill is personal/client by default (real secrets & client
# data: bank PIN, WP password, Google key, Telegram token, contracts). Only
# the `_main` + `pinger` demo agents ship publicly. Adding a new private
# agent/skill needs NO change here — it's ignored automatically.
/.orchestria/agents/*
!/.orchestria/agents/_main/
!/.orchestria/agents/pinger/
/.orchestria/skills/*
# Re-exclude runtime state even inside the public defaults (last match wins).
/.orchestria/agents/*/memory/
/.orchestria/agents/*/logs/
